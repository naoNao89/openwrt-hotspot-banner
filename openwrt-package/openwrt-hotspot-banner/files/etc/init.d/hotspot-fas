#!/bin/sh /etc/rc.common

START=99
STOP=1
USE_PROCD=1

CONFIG_SECTION="main"
PROG="/usr/bin/hotspot-fas"

load_config() {
	config_load hotspot-fas
	config_get_bool enabled "$CONFIG_SECTION" enabled 1
	config_get port "$CONFIG_SECTION" port 8080
	config_get session_minutes "$CONFIG_SECTION" session_minutes 60
	config_get disconnect_grace_seconds "$CONFIG_SECTION" disconnect_grace_seconds 300
	config_get queue_retry_seconds "$CONFIG_SECTION" queue_retry_seconds 300
	config_get max_active_sessions "$CONFIG_SECTION" max_active_sessions 30
	config_get guest_iface "$CONFIG_SECTION" guest_iface ath01
	config_get guest_ip "$CONFIG_SECTION" guest_ip 192.168.28.1
	config_get theme_dir "$CONFIG_SECTION" theme_dir /etc/hotspot-banner/theme
	config_get default_theme_dir "$CONFIG_SECTION" default_theme_dir /usr/share/hotspot-banner/default-theme
}

start_service() {
	load_config

	[ "$enabled" = "1" ] || return 0
	[ -x "$PROG" ] || return 1

	ip link add name br-guest type bridge 2>/dev/null || true
	ip link set br-guest up 2>/dev/null || true
	ip addr add "${guest_ip}/24" dev br-guest 2>/dev/null || true

	# Best-effort first attempt (covers the warm-restart case where wifi is
	# already up). The persistent watcher (below) handles the cold-boot race.
	if ip link show "$guest_iface" >/dev/null 2>&1; then
		ip link set "$guest_iface" master br-guest 2>/dev/null || true
		ip link set "$guest_iface" up 2>/dev/null || true
		GUEST_WIFI_IFACE="$guest_iface" GUEST_IP="$guest_ip" FAS_PORT="$port" sh /usr/lib/hotspot-banner/hotspot-firewall.sh 2>/dev/null || true
	fi

	# Detached watcher: keeps retrying until $guest_iface appears, then
	# enslaves + reapplies firewall + reloads dnsmasq. Survives slow QSDK boots.
	if [ -x /usr/lib/hotspot-banner/guest-watcher.sh ]; then
		# Kill any previous watcher(s) to keep at most one alive.
		# Busybox lacks pkill, and `killall guest-watcher.sh` doesn't
		# match because /proc/N/comm for a script is its interpreter
		# (sh), not the script name. Match by /proc/N/cmdline instead.
		for _p in $(grep -l guest-watcher.sh /proc/[0-9]*/cmdline 2>/dev/null); do
			_pid="${_p%/cmdline}"
			kill "${_pid##*/}" 2>/dev/null || true
		done
		# Fully detach stdio so the parent (procd, ssh, init.d caller)
		# doesn't wait on the watcher's pipes when invoked over SSH.
		GUEST_IFACE="$guest_iface" GUEST_IP="$guest_ip" FAS_PORT="$port" \
			/usr/lib/hotspot-banner/guest-watcher.sh </dev/null >/dev/null 2>&1 &
	fi

	# QSDK boxes: ensure dnsmasq picks up our static guest dhcp-range. The
	# packaged /etc/dnsmasq.d/guest.conf is loaded only if dnsmasq's main
	# config has `conf-dir=/etc/dnsmasq.d/,*.conf`. Add it idempotently.
	if [ -f /etc/dnsmasq.conf ] && ! grep -q '^conf-dir=/etc/dnsmasq\.d' /etc/dnsmasq.conf; then
		echo 'conf-dir=/etc/dnsmasq.d/,*.conf' >>/etc/dnsmasq.conf
		/etc/init.d/dnsmasq reload >/dev/null 2>&1 || /etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
		logger -t hotspot-fas "added conf-dir to /etc/dnsmasq.conf and reloaded dnsmasq"
	fi

	procd_open_instance
	procd_set_param command "$PROG"
	procd_set_param env PORT="$port" SESSION_MINUTES="$session_minutes" DISCONNECT_GRACE_SECONDS="$disconnect_grace_seconds" QUEUE_RETRY_SECONDS="$queue_retry_seconds" MAX_ACTIVE_SESSIONS="$max_active_sessions" GUEST_IFACE="$guest_iface" THEME_DIR="$theme_dir" DEFAULT_THEME_DIR="$default_theme_dir"
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_set_param respawn 3600 5 5
	procd_close_instance
}

stop_service() {
	for _p in $(grep -l guest-watcher.sh /proc/[0-9]*/cmdline 2>/dev/null); do
		_pid="${_p%/cmdline}"
		kill "${_pid##*/}" 2>/dev/null || true
	done
}
