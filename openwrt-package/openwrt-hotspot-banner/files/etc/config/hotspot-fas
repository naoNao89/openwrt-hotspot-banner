config hotspot-fas 'main'
	option enabled '1'
	option port '8080'
	option session_minutes '60'
	option disconnect_grace_seconds '300'
	option queue_retry_seconds '300'
	option max_active_sessions '30'
	option guest_iface 'ath01'
	option guest_ip '192.168.28.1'
	option theme_dir '/etc/hotspot-banner/theme'
	option default_theme_dir '/usr/share/hotspot-banner/default-theme'
